# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_here
HASH_SECRET=your_hash_secret_here

# HRIS API Integration
HRIS_URL=https://api.avegabros.org/website/auth-login
HRIS_API_KEY=your_hris_api_key_here
HRIS_USERNAME=your_hris_username_here
HRIS_PASSWORD=your_hris_password_here

# ABAS Integration (new)
ABAS_URL=https://abas-staging.avegabros.net
ABAS_API_KEY=your-abas-webhook-secret

# MinIO Configuration (new)
MINIO_ENDPOINT=minio-api.abas.ph
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your_minio_access_key_here
MINIO_SECRET_KEY=your_minio_secret_key_here
MINIO_REGION=abas-ph
MINIO_PUBLIC_URL=https://minio-api.abas.ph
MINIO_BUCKET=abas-id-requests


